CLAW_DATA_DIR=/home/clawdb/.clawdb
CLAW_LOG_LEVEL=info
CLAW_LOG_FORMAT=json
CLAW_GRPC_PORT=50050
CLAW_HTTP_PORT=8080
CLAW_METRICS_PORT=9090
CLAW_VECTOR_ENABLED=false
CLAW_GUARD_JWT_SECRET=replace-with-a-random-secret
# Optional integrations
# CLAW_SYNC_HUB_URL=https://sync.example.internal
# CLAW_REFLECT_BASE_URL=https://reflect.example.internal
# CLAW_REFLECT_API_KEY=replace-with-reflect-api-key
# CLAW_TLS_CERT_PATH=/etc/clawdb/tls/server.crt
# CLAW_TLS_KEY_PATH=/etc/clawdb/tls/server.key
